<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav"
    app:startDestination="@id/landingFragment">

    <fragment
        android:id="@+id/landingFragment"
        android:name="com.example.auranote.view.LandingFragment"
        android:label="fragment_landing"
        tools:layout="@layout/fragment_landing" >
        <action
            android:id="@+id/action_landingFragment_to_addnoteFragment"
            app:destination="@id/addnoteFragment" />
    </fragment>
    <fragment
        android:id="@+id/addnoteFragment"
        android:name="com.example.auranote.view.AddnoteFragment"
        android:label="fragment_addnote"
        tools:layout="@layout/fragment_addnote" >
        <action
            android:id="@+id/action_addnoteFragment_to_landingFragment"
            app:destination="@id/landingFragment" />
    </fragment>
</navigation>