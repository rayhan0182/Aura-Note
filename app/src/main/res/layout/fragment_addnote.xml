<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    tools:context=".view.AddnoteFragment">


    <ImageView
        android:id="@+id/back_arrow"
        android:layout_width="@dimen/_35sdp"
        android:layout_height="@dimen/_17sdp"
        android:src="@drawable/outline_keyboard_arrow_left_24"
        android:scaleType="centerCrop"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="@dimen/_10sdp"
        />

    <TextView
        android:id="@+id/title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toEndOf="@id/back_arrow"
        app:layout_constraintTop_toTopOf="parent"
        android:text="Notes"
        android:textSize="@dimen/_14ssp"
        android:textStyle="bold"
        android:textColor="#C8B619"
        android:layout_marginTop="@dimen/_8sdp"
        />


    <ImageView
        android:id="@+id/curved_array_left"
        android:layout_width="@dimen/_16sdp"
        android:layout_height="@dimen/_16sdp"
        android:src="@drawable/curved_thin_arrow_left_icon"
        android:scaleType="centerCrop"
        app:layout_constraintStart_toEndOf="@id/title"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="@dimen/_10sdp"
        />

    <ImageView
        android:id="@+id/curved_array_right"
        android:layout_width="@dimen/_16sdp"
        android:layout_height="@dimen/_16sdp"
        android:src="@drawable/curved_thin_arrow_right_icon"
        android:scaleType="centerCrop"
        app:layout_constraintStart_toEndOf="@id/curved_array_left"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginLeft="@dimen/_5sdp"
        android:layout_marginTop="@dimen/_10sdp"

        />


    <TextView
        android:id="@+id/save"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toEndOf="@id/curved_array_right"
        app:layout_constraintTop_toTopOf="parent"
        android:text="Done"
        android:textSize="@dimen/_14ssp"
        android:textStyle="bold"
        android:layout_marginTop="@dimen/_8sdp"
        android:textColor="#C8B619"
        android:layout_marginLeft="@dimen/_25sdp"
        />


    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/writing"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginLeft="@dimen/_5sdp"
        app:layout_constraintTop_toBottomOf="@id/back_arrow"
        android:layout_marginTop="@dimen/_4sdp"
        app:boxBackgroundMode="none">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/writing_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textMultiLine"
            android:textSize="@dimen/_16ssp"/>

    </com.google.android.material.textfield.TextInputLayout>





</androidx.constraintlayout.widget.ConstraintLayout>