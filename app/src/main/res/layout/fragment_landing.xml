<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="#000000"
    tools:context=".view.LandingFragment">

    <TextView
        android:id="@+id/title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="10dp"
        android:fontFamily="@font/averia_serif_libre_bold_italic"
        android:text="Write_"
        android:textColor="#F9F9F9"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <EditText
        android:id="@+id/search"
        android:layout_width="match_parent"
        android:layout_height="35dp"
        android:hint="Search"
        android:inputType="text"
        android:textColor="#ffffff"
        android:background="@drawable/box_corner_shape"
        android:layout_marginTop="20dp"
        android:layout_marginHorizontal="21dp"
        android:gravity="center"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/title"/>

      <LinearLayout
          android:id="@+id/add"
          android:layout_width="150dp"
          android:layout_height="100dp"
          android:orientation="vertical"
          android:layout_marginTop="10dp"
          android:layout_marginLeft="18dp"
          android:backgroundTint="#2E2E2E"
          android:background="@drawable/items_layoutshape"
          app:layout_constraintStart_toStartOf="parent"
          app:layout_constraintEnd_toEndOf="parent"
          app:layout_constraintTop_toBottomOf="@id/search"

          >

          <ImageView
              android:layout_width="50dp"
              android:layout_height="50dp"
              android:layout_gravity="center"
              android:src="@drawable/baseline_add_circle_24"
              android:layout_marginTop="25dp"
              />

      </LinearLayout>


    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rc"
        android:layout_width="match_parent"
        android:layout_height="500dp"
        app:layout_constraintTop_toBottomOf="@id/add"
        app:layout_constraintStart_toEndOf="@id/add"
        android:layout_marginLeft="5dp"
        android:layout_marginTop="10dp"
        tools:listitem="@layout/notes_items"


    />



</androidx.constraintlayout.widget.ConstraintLayout>